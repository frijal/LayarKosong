{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "layarkosong-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-06",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  /**
   * Bindings ke Database D1
   */
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "layarkosong-db",
      "database_id": "2ed9f46c-a124-49ff-85ce-499f2340c380"
    }
  ],
  "upload_source_maps": true
}
