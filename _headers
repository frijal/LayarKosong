# =========================================================
# 1. ATURAN GLOBAL & KEAMANAN
# Semua request akan dapet header ini otomatis
# =========================================================
/*
  X-Content-Type-Options: nosniff

# Prevent Indexing for Preview Domains
https://:project.pages.dev/*
  X-Robots-Tag: noindex

https://:version.:project.pages.dev/*
  X-Robots-Tag: noindex

# =========================================================
# 2. DATA & XML (Ringkas Menggunakan Wildcard)
# =========================================================
/*.xml
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=2419200
/artikel.json
  Cache-Control: public, max-age=1800, s-maxage=1800, stale-while-revalidate=2419200
/sitemap.txt
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=2419200
/llms.txt
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=2419200
/.well-known/llms.txt
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=2419200

# =========================================================
# 3. ASET STATIS UMUM (Long-term Cache)
# Ditulis LEBIH AWAL agar file spesifik di bawah bisa melakukan override.
# Sisa file di folder /ext/ (seperti fonts / asset pasif) aman di sini.
# =========================================================
/img/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/ext/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/favicon.ico
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/favicon.png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/thumbnail.png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/thumbnail.webp
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/thumbnail.jpg
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/site.webmanifest
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/logo.png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/*.xsl
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# =========================================================
# 4. OVERRIDE ASSET TANPA VERSIONING (KRUSIAL!)
# Wajib di bawah wildcard /ext/* agar bisa menimpa aturan immutable.
# Memaksa browser revalidasi ke Cloudflare. Efektif untuk Purge Manual.
# =========================================================
/ext/data-provider.js
  Cache-Control: public, max-age=0, s-maxage=31536000, must-revalidate
/ext/marquee-url.js
  Cache-Control: public, max-age=0, s-maxage=31536000, must-revalidate
/ext/lightbox.js
  Cache-Control: public, max-age=0, s-maxage=31536000, must-revalidate
/ext/iposbrowser.js
  Cache-Control: public, max-age=0, s-maxage=31536000, must-revalidate
/ext/response.js
  Cache-Control: public, max-age=0, s-maxage=31536000, must-revalidate

# --- CSS ABADI TANPA VERSIONING ---
# Menyelamatkan CSS dari jebakan cache setahun penuh di lokal browser.
/ext/fontawesome.css
