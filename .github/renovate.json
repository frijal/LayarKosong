{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":rebaseStalePrs"
  ],

  "enabledManagers": ["bun", "github-actions"],

  "bun": {
    "enabled": true
  },

  "rangeStrategy": "bump",

  "dependencyDashboard": true,

  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,

  "minimumReleaseAge": "2 days",

  "postUpdateOptions": [
    "bun-lockfile-fix"
  ],

  "packageRules": [
    {
      "description": "Group core web processing tools",
      "matchPackageNames": [
        "sharp",
        "@minify-html/node",
        "cheerio",
        "@xmldom/xmldom",
        "glob"
      ],
      "groupName": "web-optimizers"
    },
    {
      "description": "Group Cloudflare and Social API tools",
      "matchPackageNames": ["wrangler", "tumblr.js"],
      "groupName": "external-services",
      "automerge": true,
      "automergeType": "pr"
    },

    {
      "description": "Safe automerge for patch & minor",
      "matchUpdateTypes": ["patch", "minor"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "pr"
    },

    {
      "description": "0.x packages = semi-danger zone",
      "matchCurrentVersion": "/^0./",
      "automerge": false
    },

    {
      "description": "Major updates = always manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ],

  "vulnerabilityAlerts": {
    "labels": ["security"],
    "assignees": ["frijal"],
    "automerge": true
  }
}
