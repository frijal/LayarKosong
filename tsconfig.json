{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "resolveJsonModule": true, // Sekarang ini pasti terbaca
    "noEmit": true,           // Koma sudah ditambahkan di sini
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types"]
  }
}